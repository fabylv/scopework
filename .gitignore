# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# generated outputs
**/.next/
**/out/
**/build/
**/coverage/
.turbo/

# expo
apps/mobile/.expo
apps/mobile/node_modules
apps/*/.expo
apps/*/node_modules
packages/*/node_modules

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!apps/web/.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
