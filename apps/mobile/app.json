{
  "expo": {
    "name": "ScopeWork",
    "slug": "scopework",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "scopework",
    "splash": {
      "backgroundColor": "#151C24"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.scopework.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ScopeWork needs camera access to capture property photos for AI repair analysis.",
        "NSPhotoLibraryUsageDescription": "ScopeWork needs photo library access to upload property photos.",
        "NSLocationWhenInUseUsageDescription": "ScopeWork uses your location to tag inspection photos with the property location."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#151C24"
      },
      "package": "com.scopework.app",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE", "ACCESS_FINE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-secure-store"
    ]
  }
}
